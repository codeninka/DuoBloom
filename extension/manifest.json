{
  "manifest_version": 3,
  "name": "DuoBloom",
  "version": "1.0",
  "description": "Enhance Duolingo with Bloom's Taxonomy based challenges.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.duolingo.com/*"],
      "js": ["content/duo_tracker.js"]
    }
  ],
  "host_permissions": ["http://localhost:8000/*"]
}
